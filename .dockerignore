# ── FILE: .dockerignore ──
# Excludes files from the Docker build context.


# ── Build output ──────────────────────────────────────────────────────────────
target/

# ── IDE and editor artifacts ──────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.vscode/
*.code-workspace
.settings/
.classpath
.project
.factorypath

# ── Maven wrapper (not needed inside Docker — we use the full Maven in image) ─
.mvn/
mvnw
mvnw.cmd

# ── Git ───────────────────────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ── Docker files themselves (no circular inclusion) ───────────────────────────
Dockerfile*
docker-compose*.yml
.dockerignore

# ── Documentation and markdown ────────────────────────────────────────────────
README.md
CHANGELOG.md
*.md

# ── OS artifacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo

# ── Secrets and local config (should never enter the image) ──────────────────
.env
.env.*
*.pem
*.key
*.p12
*.jks
secrets/

# ── Test reports (generated by CI, not needed in image) ──────────────────────
surefire-reports/